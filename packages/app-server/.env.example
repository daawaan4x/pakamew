# shellcheck shell=sh
# shellcheck disable=SC2034
# ^^ Added the rules above to suppress unrelated shell warnings

NODE_ENV=development

DATABASE_URL="postgresql://pakamew:pakamew@localhost:5432/pakamew?schema=public"

BETTER_AUTH_SECRET=secret
BETTER_AUTH_URL=http://localhost:3000

HOST=127.0.0.1
PORT=3000

OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
OTEL_SERVICE_NAME=pakamew-server
OTEL_SERVICE_VERSION=0.0.0
# OTEL_DEPLOYMENT_ENVIRONMENT=development

# Preset: debug | dev | test | staging | prod
# OBS_PRESET=dev
OBS_ERROR_TRACE_WINDOW_MS=120000
# OBS_LOG_LEVEL=info
# OBS_METRICS_DETAIL_LEVEL=medium
# OBS_METRICS_EXPORT_INTERVAL_MS=10000

# OBS_ENABLE_DEV_TRACING=false
# OBS_ENABLE_ORPC_LOG_REQUEST_RESPONSE=true
# OBS_ENABLE_ORPC_LOG_REQUEST_ABORT=true
# OBS_ENABLE_PRISMA_LOG_QUERIES=true

# Collector preset env is separate.
# Copy one of:
# - packages/observability/open-telemetry/.env.debug.example
# - packages/observability/open-telemetry/.env.dev.example
# - packages/observability/open-telemetry/.env.test.example
# - packages/observability/open-telemetry/.env.staging.example
# - packages/observability/open-telemetry/.env.prod.example
# to:
# - packages/observability/open-telemetry/.env
